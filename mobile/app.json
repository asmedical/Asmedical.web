{
  "expo": {
    "name": "ASM — Assistance Sociale Médicale",
    "slug": "asm-sante",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "asmsante",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.asmsante.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.asm_sante.twa",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#0E6B3F",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Face ID protège l'accès à vos informations médicales dans ASM."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://www.asm-sante.com"
    }
  }
}
