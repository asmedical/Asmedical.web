generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Une demande faite par un patient depuis le site
model Demande {
  id         Int      @id @default(autoincrement())
  service    String   // transport | domicile | medicaments
  telephone  String
  date       String   // date souhaitée (AAAA-MM-JJ)
  recurrence String   @default("Une seule fois")
  statut     String   @default("A_RAPPELER") // A_RAPPELER | CONFIRMEE | AFFECTEE | ANNULEE
  chauffeur  String?  // affecté par l'équipe
  creeLe     DateTime @default(now())
}
