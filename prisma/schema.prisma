generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Une demande faite par un patient ou un établissement depuis le site
model Demande {
  id             Int      @id @default(autoincrement())
  service        String   // transport | domicile | medicaments
  typeTrajet     String?  // simple | accompagne | medicalise
  prefGenre      String?  // souhait du patient : homme | femme (domicile)
  signaturePath  String?  // signature de fin d'intervention (chemin stockage privé)
  nom            String?
  telephone      String
  depart         String?
  destination    String?
  date           String   // date/heure souhaitée (AAAA-MM-JJTHH:MM)
  recurrence     String   @default("Une seule fois")
  notes          String?
  details        String?  // précisions structurées (JSON : besoins, accès, proche à prévenir)
  espace         String   @default("patient") // patient | pro
  statut         String   @default("A_RAPPELER") // A_RAPPELER | CONFIRMEE | AFFECTEE | EN_COURS | TERMINEE | ABSENT | ANNULEE
  chauffeur      String?  // affecté par l'équipe (texte libre historique)
  prioritaire    Boolean  @default(false)
  sousMode       String?  // transport : abonnement | ponctuel | urgent — medicaments : fenetre | urgent
  fenetre        String?  // fenêtre souhaitée (livraison) ex. "14h-17h" ou "au plus tôt"
  pharmacie      String?  // adresse / nom de la pharmacie (livraison)
  dureeMin       Int      @default(60) // durée de la prestation (minutes) — sert au calcul des chevauchements
  commune        String?  // commune du patient (filtre de zone du moteur de disponibilités)
  parEtablissement String? // réservé AU NOM du patient par cet établissement (nom affiché)
  parEtabUserId  String?  // compte établissement ayant créé la réservation
  soignantId     Int?
  soignant       Soignant?     @relation(fields: [soignantId], references: [id])
  transporteurId Int?
  transporteur   Transporteur? @relation(fields: [transporteurId], references: [id])
  abonnementId   Int?
  abonnement     Abonnement?   @relation(fields: [abonnementId], references: [id])
  // --- Suivi d'avancement par l'intervenant (fiche mission) ---
  accepteeLe     DateTime?  // acceptée / confirmée par l'intervenant
  enRouteLe      DateTime?  // « je suis en route »
  arriveeLe      DateTime?  // « arrivée sur place »
  debutLe        DateTime?  // intervention commencée
  finLe          DateTime?  // intervention terminée
  problemeLe     DateTime?  // problème signalé
  problemeTexte  String?    // description du problème signalé
  compteRendu    String?    // compte rendu court après intervention (visible admin)
  avis           Avis?
  documents      DocumentDemande[]
  creeLe         DateTime @default(now())
}

// Aide-soignant / infirmier géré par l'admin (planning Mode A)
model Soignant {
  id            Int      @id @default(autoincrement())
  prenom        String
  nom           String
  telephone     String?
  email         String?
  photoUrl      String?
  qualification String   @default("aide_soignant") // aide_soignant | infirmier
  genre         String?  // homme | femme (choix possible du patient)
  userId        String?  @unique                   // compte de connexion Supabase lié (espace employé)
  communes      String   @default("")              // communes couvertes, séparées par des virgules
  heureDebut    Int      @default(7)               // horaires propres (défaut 7h-19h)
  heureFin      Int      @default(19)
  joursOff      String   @default("")              // jours de repos hebdo "5,6" (0=lun … 6=dim)
  conges        String   @default("")              // dates AAAA-MM-JJ séparées par des virgules
  statut        String   @default("EN_ATTENTE")    // EN_ATTENTE | VALIDE | SUSPENDU | INACTIF | REFUSE
  // --- RH étendu (fiche employé) ---
  adresse         String?
  commune         String?
  wilaya          String?
  dateNaissance   String?   // AAAA-MM-JJ
  contactUrgence  String?   // nom + téléphone d'un proche
  dispo           String    @default("DISPONIBLE")  // DISPONIBLE | OCCUPE | ABSENT
  specialites     String    @default("")            // compétences / types de soins, virgules
  accepteUrgences Boolean   @default(false)
  typeRemuneration String?  // fixe | horaire | mission | forfait
  tauxHoraire     Float?
  tarifMission    Float?
  primes          Float?
  retenues        Float?
  notesPaie       String?
  demandes      Demande[]
  avis          Avis[]
  creeLe        DateTime @default(now())
  majLe         DateTime @updatedAt @default(now())
}

// Transporteur / chauffeur (Mode B)
model Transporteur {
  id            Int      @id @default(autoincrement())
  nom           String   // nom ou société
  responsable   String?
  telephone     String?
  email         String?
  photoUrl      String?
  typeTransport String   @default("simple") // simple | accompagne | medicalise
  userId        String?  @unique             // compte de connexion Supabase lié (espace employé)
  vehicule      String?                     // modèle (ex. Renault Trafic aménagé)
  vehiculeCouleur String?                   // couleur (ex. blanc)
  vehiculeImmat String?                     // plaque d'immatriculation
  zone          String   @default("")       // communes couvertes
  statut        String   @default("EN_ATTENTE") // EN_ATTENTE | VALIDE | SUSPENDU | INACTIF | REFUSE
  // --- RH étendu (fiche employé) ---
  heureDebut      Int       @default(7)
  heureFin        Int       @default(19)
  joursOff        String    @default("")
  conges          String    @default("")
  adresse         String?
  commune         String?
  wilaya          String?
  dateNaissance   String?
  contactUrgence  String?
  dispo           String    @default("DISPONIBLE")  // DISPONIBLE | OCCUPE | ABSENT
  specialites     String    @default("")            // capacité, options du véhicule…
  accepteUrgences Boolean   @default(false)
  typeRemuneration String?  // fixe | horaire | mission | forfait
  tauxHoraire     Float?
  tarifMission    Float?
  primes          Float?
  retenues        Float?
  notesPaie       String?
  demandes      Demande[]
  avis          Avis[]
  creeLe        DateTime @default(now())
  majLe         DateTime @updatedAt @default(now())
}

// Série récurrente de transports (dialyse, chimio…)
model Abonnement {
  id        Int       @id @default(autoincrement())
  nom       String?
  telephone String
  jours     String    // jours de la semaine "0,2,4" (0=lun … 6=dim)
  heure     String    // heure de départ "08:00"
  centre    String    // destination (centre de dialyse…)
  domicile  String    // adresse de départ
  retour    Boolean   @default(true) // rappel en fin de séance pour le retour
  debut     String    // AAAA-MM-JJ
  fin       String    // AAAA-MM-JJ
  statut    String    @default("ACTIF") // ACTIF | SUSPENDU | TERMINE
  demandes  Demande[]
  creeLe    DateTime  @default(now())
}

// Type d'acte à domicile (Mode A) : durée propre, qualification requise
model TypeActe {
  id            Int     @id @default(autoincrement())
  libelle       String
  libelleAr     String  @default("")
  dureeMin      Int     @default(60)
  qualification String  @default("aide_soignant") // aide_soignant | infirmier
  actif         Boolean @default(true)
}

// Messagerie patient/établissement ↔ équipe ASM. Un fil par compte
// (userId = uuid Supabase). deEquipe distingue l'expéditeur.
model Message {
  id           Int      @id @default(autoincrement())
  userId       String
  deEquipe     Boolean  @default(false)
  auteur       String?  // nom de l'agent quand deEquipe = true
  texte        String
  luParPatient Boolean  @default(false) // messages équipe lus par le patient
  luParEquipe  Boolean  @default(false) // messages patient lus par l'équipe
  creeLe       DateTime @default(now())

  @@index([userId, creeLe])
}

// Message officiel / notification envoyé par l'équipe à un compte :
// info, demande de document, mise à jour de rendez-vous, rappel…
// Distinct du chat (Message) : consultable durablement, avec statut.
model Notification {
  id      Int       @id @default(autoincrement())
  userId  String
  type    String    @default("message") // message | document | rdv | rappel
  titre   String
  corps   String?
  docType String?   // pour type=document : piece_identite | ordonnance | justificatif | medical | autre
  lienType String?  // entité liée : intervention | demande (pour ouvrir la bonne page)
  lienId   String?  // id de l'entité liée
  auteur  String?   // agent qui l'a envoyée
  statut  String    @default("NON_LU") // NON_LU | LU | TRAITEE
  luLe    DateTime?
  creeLe  DateTime  @default(now())

  @@index([userId, creeLe])
}

// Procuration / rattachement d'un patient à un établissement partenaire.
// L'établissement ne peut agir POUR un patient que si un rattachement
// ACCEPTE, non expiré et couvrant le service existe.
// Document rattaché à UNE demande (ordonnance de livraison, bon…).
// Le fichier vit dans le bucket privé « documents » ; ici les métadonnées.
model DocumentDemande {
  id        Int      @id @default(autoincrement())
  demandeId Int
  demande   Demande  @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  categorie String   @default("ordonnance") // ordonnance | bon | autre
  nom       String
  chemin    String   // chemin dans le bucket privé
  mime      String?
  taille    Int?
  par       String?  // patient | proche | staff
  creeLe    DateTime @default(now())

  @@index([demandeId])
}

// Préférences de soin du patient : consignes pratiques (accès, allergies)
// visibles UNIQUEMENT par l'intervenant affecté, préférence de genre et
// intervenant favori (prioritaires à l'affectation automatique).
model PreferencePatient {
  id               Int      @id @default(autoincrement())
  userId           String   @unique // compte propriétaire
  telCle           String   // 8 derniers chiffres du téléphone (correspondance demandes)
  allergies        String?
  etage            String?
  codePorte        String?
  consignes        String?
  prefGenre        String?  // homme | femme
  soignantFavoriId Int?
  majLe            DateTime @updatedAt @default(now())

  @@index([telCle])
}

model Rattachement {
  id           Int       @id @default(autoincrement())
  patientTel   String    // téléphone du patient (identité de réservation)
  patientNom   String?   // nom saisi par l'établissement (affichage)
  etabUserId   String?   // compte Supabase du bénéficiaire (établissement OU proche)
  etabNom      String?   // nom d'affichage de l'établissement ou du proche
  type         String    @default("etablissement") // etablissement | proche
  statut       String    @default("EN_ATTENTE") // EN_ATTENTE | ACCEPTE | REFUSE | REVOQUE | CODE_ATTENTE
  source       String    @default("invitation") // invitation | code | staff | document
  scopes       String    @default("transport,domicile,medicaments") // services autorisés
  code         String?   @unique // code de rattachement généré par le patient
  codeExpire   DateTime? // expiration du code (usage unique)
  expiration   String?   // fin d'autorisation AAAA-MM-JJ (vide = jusqu'à révocation)
  decideLe     DateTime? // acceptation / refus par le patient
  revoqueLe    DateTime?
  creeLe       DateTime  @default(now())
  majLe        DateTime  @updatedAt @default(now())

  @@index([patientTel])
  @@index([etabUserId])
}

// Abonnement aux notifications push (Web Push) d'un appareil.
// Un utilisateur peut avoir plusieurs appareils (téléphone, tablette…).
model PushAbonnement {
  id       Int      @id @default(autoincrement())
  userId   String
  endpoint String   @unique
  p256dh   String
  auth     String
  creeLe   DateTime @default(now())

  @@index([userId])
}

// Avis d'un patient après une intervention terminée (note + commentaire).
model Avis {
  id             Int           @id @default(autoincrement())
  demandeId      Int           @unique
  demande        Demande       @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  soignantId     Int?
  soignant       Soignant?     @relation(fields: [soignantId], references: [id], onDelete: SetNull)
  transporteurId Int?
  transporteur   Transporteur? @relation(fields: [transporteurId], references: [id], onDelete: SetNull)
  note           Int           // 1 à 5
  commentaire    String?
  telephone      String        // identité patient (contrôle d'appartenance)
  creeLe         DateTime      @default(now())

  @@index([soignantId])
  @@index([transporteurId])
}

// Document RH d'un employé (pièce d'identité, diplôme, permis, contrat…).
// Fichier stocké dans Supabase Storage (bucket privé), métadonnées ici.
model DocumentEmploye {
  id         Int      @id @default(autoincrement())
  userId     String   // compte employé (uuid Supabase)
  categorie  String   @default("autre") // piece_identite | diplome | certificat | permis | assurance | carte_grise | contrat | rib | autre
  nom        String
  chemin     String   // chemin dans le bucket Storage
  taille     Int      @default(0)
  typeMime   String   @default("")
  statut     String   @default("EN_ATTENTE") // EN_ATTENTE | VALIDE | REFUSE
  remarque   String?  // commentaire admin (visible par l'employé)
  expiration String?  // date d'expiration AAAA-MM-JJ (permis, assurance…)
  deposePar  String   @default("employe") // employe | admin
  creeLe     DateTime @default(now())
  majLe      DateTime @updatedAt @default(now())

  @@index([userId])
}

// Demande de suppression d'un compte : un admin/modérateur la soumet,
// SEUL le super admin l'exécute (valide) ou la refuse.
model DemandeSuppression {
  id         Int      @id @default(autoincrement())
  cibleType  String   // client | soignant | transporteur
  cibleId    String   // uuid profil ou id numérique
  cibleNom   String?
  motif      String?
  demandePar String   // nom affiché du demandeur
  statut     String   @default("EN_ATTENTE") // EN_ATTENTE | VALIDEE | REFUSEE
  decidePar  String?
  decideLe   DateTime?
  creeLe     DateTime @default(now())

  @@index([statut])
}

// Note interne (jamais visible côté patient)
model NoteInterne {
  id       Int      @id @default(autoincrement())
  entite   String   // demande | client | soignant | transporteur
  entiteId String   // id de l'entité (texte : couvre uuid profil et id numérique)
  auteur   String
  texte    String
  creeLe   DateTime @default(now())
}

// Journal des actions admin (qui a fait quoi, quand, sur quoi)
model Journal {
  id       Int      @id @default(autoincrement())
  auteur   String
  action   String   // ex. "demande.statut", "soignant.valide"
  entite   String
  entiteId String
  detail   String?
  creeLe   DateTime @default(now())
}

// Réglages du calendrier de créneaux (ligne unique id=1), éditables
// par l'équipe dans le back-office.
model Reglage {
  id                  Int @id @default(1)
  heureDebut          Int @default(7)   // service à partir de 7h
  heureFin            Int @default(19)  // jusqu'à 19h
  dureeCreneauMin     Int @default(60)  // créneaux d'1 heure
  joursHorizon        Int @default(14)  // réservable jusqu'à 14 jours
  capaciteTransport   Int @default(3)   // 3 transports en parallèle
  capaciteDomicile    Int @default(2)
  capaciteMedicaments Int @default(3)
  // --- Moteur de disponibilités par ressources ---
  tamponMin           Int     @default(15)    // temps tampon après chaque intervention (min)
  trajetDefautMin     Int     @default(20)    // déplacement estimé entre deux interventions (min)
  capaciteFenetre     Int     @default(8)     // livraisons max par fenêtre (matin/midi/soir)
  affectationAuto     Boolean @default(false) // affecter automatiquement l'intervenant le moins chargé
  facturationAuto     Boolean @default(true)  // facturer automatiquement à la clôture d'une prestation
}

// Canal choisi par l'utilisateur pour recevoir son code de connexion
// (sms | whatsapp). Consulté par le hook d'envoi au moment de l'OTP.
model OtpCanal {
  id        Int      @id @default(autoincrement())
  telephone String   @unique // format E.164
  canal     String   @default("sms")
  majLe     DateTime @updatedAt @default(now())
}

// ═══════════════ MODULE FINANCIER ASM ═══════════════
// Montants en DINARS ENTIERS (DZD). Aucune donnée de carte stockée.

// Séquences fiables (numéros clients, factures, paiements) — jamais réutilisées.
model SequenceFinance {
  nom    String @id
  valeur Int    @default(0)
}

// Compte financier unique par client (patient ou établissement).
model CompteFinancier {
  id               Int      @id @default(autoincrement())
  numero           String   @unique // ASM-CL-000001
  userId           String   @unique // compte de connexion (profil)
  type             String   @default("patient") // patient | pro
  nom              String?
  devise           String   @default("DZD")
  emailFacturation String?
  telFacturation   String?
  statut           String   @default("ACTIF")
  modeFacturation  String   @default("prestation") // prestation (auto à la clôture) | mensuel (groupée fin de mois)
  factures         Facture[]
  remises          RemiseClient[]
  souscriptions    Souscription[]
  creeLe           DateTime @default(now())
  majLe            DateTime @updatedAt @default(now())
}

// Tarifs administrables et VERSIONNÉS (une modification clôt la version
// courante et en crée une nouvelle ; jamais rétroactif : les factures
// copient les montants au moment de l'émission).
model Tarif {
  id         Int      @id @default(autoincrement())
  categorie  String   // transport | domicile | medicaments | supplement | penalite
  code       String   // ex. transport_base, nuit, weekend, km_sup, annulation_tardive
  libelle    String
  libelleAr  String?
  montant    Int      // DZD
  unite      String   @default("prestation") // prestation | heure | km
  service    String?  // service concerné (filtre)
  zone       String?
  clientType String?  // patient | pro | null = tous
  debut      String   // AAAA-MM-JJ (début de validité de la version)
  fin        String?  // null = en vigueur
  actif      Boolean  @default(true)
  creePar    String?
  creeLe     DateTime @default(now())
}

model Facture {
  id             Int      @id @default(autoincrement())
  numero         String   @unique // ASM-2026-000001
  compteId       Int
  compte         CompteFinancier @relation(fields: [compteId], references: [id])
  demandeId      Int?
  souscriptionId Int?
  statut         String   @default("EMISE") // BROUILLON|EMISE|PARTIELLEMENT_PAYEE|PAYEE|EN_RETARD|ANNULEE|CREDITEE
  emissionLe     String   // AAAA-MM-JJ
  echeance       String   // AAAA-MM-JJ
  sousTotal      Int
  remiseTotal    Int      @default(0)
  remiseDetail   String?  // libellé affiché (ex. « Remise fidélité ASM : -10 % »)
  total          Int
  paye           Int      @default(0)
  devise         String   @default("DZD")
  notes          String?
  creePar        String?
  annuleePar     String?
  annuleeLe      DateTime?
  lignes         LigneFacture[]
  paiements      Paiement[]
  tickets        TicketEspeces[]
  relances       RelancePaiement[]
  creeLe         DateTime @default(now())
  majLe          DateTime @updatedAt @default(now())
}

model LigneFacture {
  id           Int     @id @default(autoincrement())
  factureId    Int
  facture      Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  libelle      String
  quantite     Int     @default(1)
  prixUnitaire Int
  montant      Int
  tarifId      Int?    // version de tarif utilisée (traçabilité)
  demandeId    Int?    // prestation facturée par cette ligne (factures groupées)
}

model Paiement {
  id             Int      @id @default(autoincrement())
  reference      String   @unique // ASM-P-000001 (sert aussi de n° de reçu)
  compteId       Int
  factureId      Int?
  facture        Facture? @relation(fields: [factureId], references: [id])
  moyen          String   // especes | cib | edahabia | virement
  fournisseur    String?  // interne | chargily | ...
  refFournisseur String?  // id du checkout / référence virement
  montant        Int
  statut         String   @default("EN_ATTENTE") // EN_ATTENTE|CONFIRME|ECHOUE|EXPIRE|ANNULE|PARTIELLEMENT_REMBOURSE|REMBOURSE
  encaissePar    String?  // caissier (espèces) / valideur (virement)
  pointId        Int?
  idem           String?  @unique // clé d'idempotence (anti double débit)
  remboursements Remboursement[]
  creeLe         DateTime @default(now())
  confirmeLe     DateTime?
}

// Ticket de paiement en espèces — à usage unique, référence non devinable.
model TicketEspeces {
  id          Int      @id @default(autoincrement())
  reference   String   @unique // ASM-T-XXXXXXXX
  jeton       String   @unique // secret du QR (vérification staff)
  compteId    Int
  factureId   Int
  facture     Facture  @relation(fields: [factureId], references: [id])
  montant     Int
  statut      String   @default("EN_ATTENTE") // EN_ATTENTE|PAYE|EXPIRE|ANNULE
  expireLe    DateTime
  payeLe      DateTime?
  encaissePar String?
  pointId     Int?
  creeLe      DateTime @default(now())
}

model Remboursement {
  id             Int      @id @default(autoincrement())
  paiementId     Int
  paiement       Paiement @relation(fields: [paiementId], references: [id])
  montant        Int
  motif          String
  statut         String   @default("EFFECTUE") // EFFECTUE | EN_ATTENTE_FOURNISSEUR | REFUSE
  validePar      String
  refFournisseur String?
  creeLe         DateTime @default(now())
}

// Remises personnalisées par client (jamais de prix négatif).
model RemiseClient {
  id       Int     @id @default(autoincrement())
  compteId Int
  compte   CompteFinancier @relation(fields: [compteId], references: [id], onDelete: Cascade)
  type     String  // pourcentage | fixe
  valeur   Int
  service  String? // null = tous les services
  motif    String
  debut    String  // AAAA-MM-JJ
  fin      String?
  plafond  Int?    // remise max par facture (DZD)
  auteur   String
  creeLe   DateTime @default(now())
}

model PointPaiement {
  id          Int     @id @default(autoincrement())
  nom         String
  typePoint   String  @default("agence") // agence | partenaire | autre
  adresse     String?
  commune     String?
  horaires    String?
  telephone   String?
  responsable String?
  plafond     Int?
  consignes   String?
  actif       Boolean @default(true)
  creeLe      DateTime @default(now())
}

// Journal des webhooks fournisseurs (idempotence + retraitement).
model EvenementPaiement {
  id          Int      @id @default(autoincrement())
  fournisseur String
  evenementId String   @unique
  type        String
  statut      String   @default("RECU") // RECU|TRAITE|IGNORE|ERREUR
  erreur      String?
  creeLe      DateTime @default(now())
}

// Plans d'abonnement / forfaits (facturation périodique).
model PlanAbonnement {
  id              Int     @id @default(autoincrement())
  nom             String
  description     String?
  prix            Int
  devise          String  @default("DZD")
  frequence       String  @default("mensuel")
  service         String?
  quantiteIncluse Int?
  actif           Boolean @default(true)
  souscriptions   Souscription[]
  creeLe          DateTime @default(now())
}

model Souscription {
  id               Int    @id @default(autoincrement())
  compteId         Int
  compte           CompteFinancier @relation(fields: [compteId], references: [id])
  planId           Int
  plan             PlanAbonnement @relation(fields: [planId], references: [id])
  statut           String @default("ACTIF") // ACTIF|SUSPENDU|ANNULE|EXPIRE|EN_ATTENTE_PAIEMENT
  debut            String
  fin              String?
  prix             Int    // copie du prix au moment de la souscription
  derniereFacture  String? // AAAA-MM (dernier mois facturé — anti doublon)
  creePar          String?
  creeLe           DateTime @default(now())
}

// Relances d'impayés — une seule par facture et par niveau.
model RelancePaiement {
  id        Int      @id @default(autoincrement())
  factureId Int
  facture   Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)
  niveau    String   // rappel | echeance | relance1 | relance2 | admin
  canal     String   // interne | email
  par       String?
  envoyeLe  DateTime @default(now())
  @@unique([factureId, niveau])
}
