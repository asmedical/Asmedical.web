# ============================================================
# ASM — Variables d'environnement (NOMS uniquement, sans valeurs)
# Copier dans Vercel → Settings → Environment Variables.
# NE JAMAIS committer les vraies valeurs / clés dans le dépôt.
# ============================================================

# --- Base de données (Railway / PostgreSQL) — INDISPENSABLE ---
DATABASE_URL=

# --- Supabase (comptes + documents) — INDISPENSABLE ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret côté serveur uniquement (jamais exposé au navigateur) :
SUPABASE_SERVICE_ROLE_KEY=

# --- Domaine officiel (pour sitemap / liens absolus) ---
NEXT_PUBLIC_SITE_URL=

# --- Route de statut détaillée /api/status (secret au choix) ---
STATUS_TOKEN=

# --- Mode maintenance : mettre "on" pour afficher la page de maintenance ---
MAINTENANCE_MODE=

# --- Notifications équipe (optionnel : au moins un canal) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK_URL=

# --- SMS : routage automatique par numéro ---
# Algérie (+213) → Elite SMS ; international → Twilio.
# Secret du « Send SMS Hook » Supabase (format v1,whsec_… ) :
SMS_HOOK_SECRET=
# Forçage d'un fournisseur unique (optionnel — pour tests) :
#   mock | twilio | elite_sms | sms_partner | infobip
SMS_PROVIDER=
SMS_EXPEDITEUR=
# Elite SMS (SMS nationaux algériens) :
ELITESMS_API_KEY=
ELITESMS_USER_KEY=
ELITESMS_BASE_URL=
# Twilio (SMS internationaux) :
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=

# --- Email transactionnel (Brevo, invitations / notifications) ---
BREVO_API_KEY=
EMAIL_EXPEDITEUR=
EMAIL_EXPEDITEUR_NOM=

# --- Notifications push web (clés VAPID) ---
# Publique (exposée au navigateur, c'est normal) :
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Privée (serveur uniquement — JAMAIS dans le code ni côté client) :
VAPID_PRIVATE_KEY=

# --- ⚠️ MODE TEST OTP (code SMS fixe, ex. 123456) ---
# À SUPPRIMER IMPÉRATIVEMENT avant l'ouverture au public :
# tant que cette variable existe, n'importe qui peut se connecter
# avec n'importe quel numéro + ce code.
OTP_TEST_CODE=

# --- Logs verbeux en production (0 = silencieux, 1 = détaillé) ---
LOG_VERBOSE=

# --- Code de connexion par WhatsApp (Meta Cloud API, optionnel) ---
# App Meta Business + numéro vérifié + modèle d'AUTHENTIFICATION approuvé.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE=
WHATSAPP_TEMPLATE_LANGUE=

# --- Connexion Google / Facebook / Apple (optionnel) ---
# Activer chaque fournisseur dans Supabase (Authentication → Providers),
# puis lister ici ceux à afficher, ex. "google,facebook,apple".
NEXT_PUBLIC_OAUTH_PROVIDERS=
