# ============================================================
# ASM — Variables d'environnement (NOMS uniquement, sans valeurs)
# Copier dans Vercel → Settings → Environment Variables.
# NE JAMAIS committer les vraies valeurs / clés dans le dépôt.
# ============================================================

# --- Base de données (Railway / PostgreSQL) — INDISPENSABLE ---
DATABASE_URL=

# --- Supabase (comptes + documents) — INDISPENSABLE ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret côté serveur uniquement (jamais exposé au navigateur) :
SUPABASE_SERVICE_ROLE_KEY=

# --- Back-office équipe ---
NEXT_PUBLIC_CODE_PRO=

# --- Domaine officiel (pour sitemap / liens absolus) ---
NEXT_PUBLIC_SITE_URL=

# --- Route de statut détaillée /api/status (secret au choix) ---
STATUS_TOKEN=

# --- Mode maintenance : mettre "on" pour afficher la page de maintenance ---
MAINTENANCE_MODE=

# --- Notifications équipe (optionnel : au moins un canal) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_WEBHOOK_URL=

# --- Passerelle SMS (à renseigner quand le fournisseur est choisi) ---
SMS_API_URL=
SMS_API_KEY=
SMS_EXPEDITEUR=

# --- Logs verbeux en production (0 = silencieux, 1 = détaillé) ---
LOG_VERBOSE=
